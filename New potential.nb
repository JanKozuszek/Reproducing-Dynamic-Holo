  RowBox[{"replfun", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Vars", "[", 
          RowBox[{"[", "ii", "]"}], "]"}], "->", 
         RowBox[{"ToExpression", "[", 
          RowBox[{"varnames", "[", 
           RowBox[{"[", "ii", "]"}], "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"Vars", "[", 
            RowBox[{"[", "ii", "]"}], "]"}], ",", "z"}], "]"}], "->", 
         RowBox[{"ToExpression", "[", 
