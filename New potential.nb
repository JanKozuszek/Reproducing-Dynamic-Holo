 RowBox[{"Clear", "[", "S0", "]"}]], "Input",
 CellChangeTimes->{{3.970751856063168*^9, 3.9707518576103*^9}},
 CellLabel->
  "In[443]:=",ExpressionUUID->"79c09e0c-ccad-4a0e-9993-fc2b99d4cb87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stepeq", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubscriptBox["\[CapitalPhi]fun", "d"], "[", 
          RowBox[{"r", ",", "t"}], "]"}], "-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"\[CapitalPhi]fun", "[", 
              RowBox[{"r", ",", "t"}], "]"}], ",", "t"}], "]"}], "+", 
           RowBox[{
            FractionBox["1", "2"], 
            RowBox[{"Afun", "[", 
             RowBox[{"r", ",", "t"}], "]"}], 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"\[CapitalPhi]fun", "[", 
               RowBox[{"r", ",", "t"}], "]"}], ",", "r"}], "]"}]}]}], ")"}]}],
         ")"}], "//.", 
       RowBox[{"D", "[", 
        RowBox[{"replWithSub", ",", "t"}], "]"}]}], "//.", "replWithSub"}], "//.",
      "RtoZ"}], "//", "Simplify"}]}], ";"}]], "Input",
 CellChangeTimes->{3.970645965357057*^9},
 CellLabel->
  "In[444]:=",ExpressionUUID->"9659140d-d9e2-4faa-a16c-dc3812e74374"],

Cell[BoxData[
 RowBox[{
  RowBox[{"solTimeStep", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{"0", "==", "stepeq"}], ",", "  ", 
        RowBox[{
         SuperscriptBox["PhiSub", 
          TagBox[
           RowBox[{"(", 
            RowBox[{"0", ",", "1"}], ")"}],
           Derivative],
          MultilineFunction->None], "[", 
         RowBox[{"z", ",", "t"}], "]"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], "//", "Expand"}], "//", "Simplify"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{3.970645978387231*^9},
 CellLabel->
  "In[179]:=",ExpressionUUID->"9936781a-dab2-43f0-8155-7dc45ca0aef4"],

Cell[TextData[{
 "We need \[Xi]\[CloseCurlyQuote][t] here. We get it by demanding that the \
apparent horizon stay in the same spot. To that end, we demand ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "t"], 
     OverscriptBox["S", "."]}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["z", "AH"], ",", "t"}], ")"}]}], "=", "0"}]],
  ExpressionUUID->"9e6968c9-f64e-49d4-98a1-ebe2486ed46f"],
 " and we take ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["z", "AH"], "=", 
    RowBox[{"1", "/", "2."}]}], TraditionalForm]],ExpressionUUID->
  "270be743-bda6-40c4-b67e-225030201ada"],
 " This requires solving  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "A", " ", 
      RowBox[{
       OverscriptBox["S", "."], "'"}]}], "+", 
     RowBox[{
      FractionBox["2", "3"], "S", " ", 
      SuperscriptBox[
       OverscriptBox["\[CapitalPhi]", "."], "2"]}], "-", 
     RowBox[{
      FractionBox["1", "2"], 
      OverscriptBox["S", "."], 
      RowBox[{"A", "'"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "f67ea721-7caf-49ea-8762-e2ded24c7455"],
 "."
}], "Text",
 CellChangeTimes->{{3.9701100581268463`*^9, 3.970110143169463*^9}, {
  3.970110942600182*^9, 3.9701109997191763`*^9}, {3.970826120676867*^9, 
  3.970826132172635*^9}},ExpressionUUID->"789e19d7-7d31-4a87-ab51-\
e413cde98e3f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solconstr", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0", "==", "constrEq"}], "//.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           SubscriptBox["Sfun", "dd"], "[", 
           RowBox[{"r", ",", "t"}], "]"}], "->", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{
               SubscriptBox["Sfun", "d"], "[", 
               RowBox[{"r", ",", "t"}], "]"}], ",", "t"}], "]"}], "+", 
            RowBox[{
             FractionBox["1", "2"], 
             RowBox[{"Afun", "[", 
              RowBox[{"r", ",", "t"}], "]"}], 
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{
                SubscriptBox["Sfun", "d"], "[", 
                RowBox[{"r", ",", "t"}], "]"}], ",", "r"}], "]"}]}]}], 
           ")"}]}], "}"}]}], ",", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["Sfun", "d"], 
         TagBox[
          RowBox[{"(", 
           RowBox[{"0", ",", "1"}], ")"}],
          Derivative],
         MultilineFunction->None], "[", 
        RowBox[{"r", ",", "t"}], "]"}]}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}], "//", "Simplify"}], "//", 
   "Expand"}]}]], "Input",
 CellChangeTimes->{{3.971946116780469*^9, 3.9719461715676003`*^9}, {
  3.9719462146364117`*^9, 3.971946218021106*^9}},
 CellLabel->
