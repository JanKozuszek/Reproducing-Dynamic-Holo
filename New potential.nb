Cell[CellGroupData[{

Cell["Ricci and Einstein tensors", "Subsection",
 CellChangeTimes->{{3.8456249526826067`*^9, 
  3.8456249576961126`*^9}},ExpressionUUID->"66557cfa-6162-40d8-bc21-\
320536d7b6df"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Ricci", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"Riemann", "[", 
         RowBox[{"[", 
          RowBox[{"\[Lambda]", ",", "\[Mu]", ",", "\[Lambda]", ",", "\[Nu]"}],
           "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Lambda]", ",", "1", ",", "Ndim"}], "}"}]}], "]"}], "]"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", ",", "1", ",", "Ndim"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Nu]", ",", "1", ",", "Ndim"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "=", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"gup", "[", 
        RowBox[{"[", 
         RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], 
       RowBox[{"Ricci", "[", 
        RowBox[{"[", 
         RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Mu]", ",", "1", ",", "Ndim"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Nu]", ",", "1", ",", "Ndim"}], "}"}]}], "]"}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Einstein", "=", 
   RowBox[{
    RowBox[{"Ricci", "-", 
