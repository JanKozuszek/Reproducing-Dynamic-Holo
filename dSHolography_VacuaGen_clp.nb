            RowBox[{"V", "[", "\[Phi]h", "]"}], " ", 
            SuperscriptBox[
             RowBox[{
              SuperscriptBox["V", "\[Prime]",
               MultilineFunction->None], "[", "\[Phi]h", "]"}], "2"]}], "+", 
           RowBox[{"18", " ", 
            SuperscriptBox[
             RowBox[{
              SuperscriptBox["V", "\[Prime]",
               MultilineFunction->None], "[", "\[Phi]h", "]"}], "2"], " ", 
            RowBox[{
             SuperscriptBox["V", "\[Prime]\[Prime]",
              MultilineFunction->None], "[", "\[Phi]h", "]"}]}]}], 
          RowBox[{"4725", " ", 
           SuperscriptBox["H", "2"]}]]}]}], ",", 
