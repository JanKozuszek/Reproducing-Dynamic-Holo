       RowBox[{"-", "e\[Epsilon]0"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]1", "=", 
     RowBox[{"10", "^", 
      RowBox[{"(", 
       RowBox[{"-", "e\[Epsilon]1"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fileMetricfunction", "=", 
     RowBox[{"\"\<mf_phiM_\>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"N", "[", 
