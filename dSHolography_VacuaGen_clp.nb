Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Super", " ", "Potential"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"WW", "[", "\[Phi]_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "3"}], "/", "2"}], "-", 
     RowBox[{
      RowBox[{"\[Phi]", "^", "2"}], "/", "2"}], "-", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Phi]", "^", "4"}], "/", "4"}], "/", 
      RowBox[{"\[Phi]M", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"\[Phi]", "^", "6"}], " ", "\[Phi]QI"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"VV", "[", "\[Phi]_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], "/", "3"}], " ", 
      RowBox[{
       RowBox[{"WW", "[", "\[Phi]", "]"}], "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{
       RowBox[{
        RowBox[{"WW", "'"}], "[", "\[Phi]", "]"}], "^", "2"}]}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sV", "=", 
     RowBox[{"V", "\[Rule]", " ", 
      RowBox[{"Function", "[", 
       RowBox[{"x", ",", 
        RowBox[{"VV", "[", "x", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"\[Phi]E", "=", 
    RowBox[{"x", "/.", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"VV", "'"}], "[", "x", "]"}], "\[Equal]", "0"}], "/.", 
        "smodel"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.5"}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"\[Phi]EHP", "=", 
    RowBox[{"x", "/.", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"VV", "'"}], "[", "x", "]"}], "\[Equal]", "0"}], "/.", 
        "smodel"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"25", "/", "10"}]}], "}"}], ",", 
       RowBox[{"WorkingPrecision", "\[Rule]", "50"}]}], "]"}]}]}], "\[IndentingNewLine]", 
