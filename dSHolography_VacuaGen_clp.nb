Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Near", " ", "Horizon"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sNHs", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"A", "\[Rule]", 
        RowBox[{"Function", "[", 
         RowBox[{"x", ",", 
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"i", "=", "1"}], "4"], 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"x", "-", "1"}], ")"}], "i"], " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", "i"}], " ", 
            RowBox[{"ah", "[", "i", "]"}]}]}]}], "]"}]}], " ", ",", 
       RowBox[{"\[Phi]0", "\[Rule]", 
        RowBox[{"Function", "[", 
         RowBox[{"x", ",", 
          RowBox[{"\[Phi]h", "+", 
           RowBox[{
            UnderoverscriptBox["\[Sum]", 
             RowBox[{"i", "=", "1"}], "4"], 
            RowBox[{
             RowBox[{"phih", "[", "i", "]"}], " ", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "-", "x"}], ")"}], "i"]}]}]}]}], " ", "]"}]}]}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
