Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Solver", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"gsR", "[", 
    RowBox[{"\[Phi]H_", ",", "\[Epsilon]h_", ",", "\[Epsilon]b_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"IC", ",", "ts"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"IC", "=", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"S", "[", 
                RowBox[{"1", "-", "\[Epsilon]h"}], "]"}], "\[Equal]", 
               RowBox[{"Normal", "[", "SnHps", "]"}]}], "/.", 
              RowBox[{"u", "\[Rule]", " ", 
               RowBox[{"1", "-", "\[Epsilon]h"}]}]}], "/.", "sV"}], "/.", 
            "smodel"}], "/.", 
           RowBox[{"\[Phi]h", "\[Rule]", " ", "\[Phi]H"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"S", "'"}], "[", 
                RowBox[{"1", "-", "\[Epsilon]h"}], "]"}], "\[Equal]", 
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"Normal", "[", "SnHps", "]"}], ",", "u"}], "]"}]}], "/.", 
              RowBox[{"u", "\[Rule]", " ", 
               RowBox[{"1", "-", "\[Epsilon]h"}]}]}], "/.", "sV"}], "/.", 
            "smodel"}], "/.", 
           RowBox[{"\[Phi]h", "\[Rule]", " ", "\[Phi]H"}]}], ",", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"1", "-", "\[Epsilon]h"}], "]"}], "==", 
           RowBox[{"Normal", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
