Cell[BoxData[{
 RowBox[{
  RowBox[{"Ricci", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"Riemann", "[", 
         RowBox[{"[", 
          RowBox[{"\[Lambda]", ",", "\[Mu]", ",", "\[Lambda]", ",", "\[Nu]"}],
