Cell[BoxData[
 RowBox[{
  RowBox[{"HtoZ", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["f_", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"2", ",", "0", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"h", ",", "t", ",", "r"}], "]"}], "->", 
      RowBox[{
       RowBox[{
        SuperscriptBox["z", "4"], 
        RowBox[{
         SuperscriptBox["f", 
          TagBox[
           RowBox[{"(", 
            RowBox[{"2", ",", "0", ",", "0"}], ")"}],
           Derivative],
          MultilineFunction->None], "[", 
         RowBox[{"z", ",", "t", ",", "r"}], "]"}]}], "+", 
       RowBox[{"2", 
        SuperscriptBox["z", "3"], 
        RowBox[{
         SuperscriptBox["f", 
          TagBox[
           RowBox[{"(", 
            RowBox[{"1", ",", "0", ",", "0"}], ")"}],
           Derivative],
          MultilineFunction->None], "[", 
         RowBox[{"z", ",", "t", ",", "r"}], "]"}]}]}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["f_", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"1", ",", "0", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"h", ",", "t", ",", "r"}], "]"}], "->", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["z", "2"]}], 
       RowBox[{
        SuperscriptBox["f", 
         TagBox[
          RowBox[{"(", 
           RowBox[{"1", ",", "0", ",", "0"}], ")"}],
          Derivative],
         MultilineFunction->None], "[", 
        RowBox[{"z", ",", "t", ",", "r"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"f_", "[", 
       RowBox[{"h", ",", "t", ",", "r"}], "]"}], "->", 
      RowBox[{"f", "[", 
       RowBox[{"z", ",", "t", ",", "r"}], "]"}]}], ",", 
     RowBox[{"h", "->", 
      FractionBox["1", "z"]}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9727118440954447`*^9, 3.972711883131962*^9}},
 CellLabel->
  "In[177]:=",ExpressionUUID->"ad5ab0f3-a89c-4904-8858-7aae5b016951"],

